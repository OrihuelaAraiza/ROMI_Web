{
  "name": "romi-web",
  "version": "0.1.0",
  "private": true,
  "description": "ROMI telehealth platform – monorepo root",
  "workspaces": [
    "romi-web-frontend",
    "romi-web-backend"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace=romi-web-frontend",
    "dev:backend": "npm run start:dev --workspace=romi-web-backend",
    "build:frontend": "npm run build --workspace=romi-web-frontend",
    "build:backend": "npm run build --workspace=romi-web-backend"
  }
}
